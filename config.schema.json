{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airtype.local/config.schema.json",
  "title": "AirType config.toml",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "localapp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chinese-mode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["zh-tw", "zh-cn"], "default": "zh-tw" }
          }
        },
        "backend-endpoint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["local", "remote"], "default": "local" },
            "local_endpoint": { "type": "string", "default": "http://127.0.0.1:8003" },
            "remote_endpoint": { "type": "string", "default": "" }
          }
        },
        "microphone": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "selected_device_name": { "type": "string", "default": "" },
            "mode": { "type": "string", "enum": ["on_demand", "always"], "default": "on_demand" },
            "pre_roll_seconds": { "type": "number", "minimum": 0, "maximum": 5, "default": 2 }
          }
        },
        "floating-dialog": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "position_x_ratio": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2598 },
            "position_y_ratio": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.0597 },
            "move_lock": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "webui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "data_dir": {
              "type": "string",
              "default": "~/.airtype/data",
              "description": "Web UI runtime data directory. Records are stored under data_dir/records/{ime,transcript}."
            }
          }
        },
        "whisper-server": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "model_dir": { "type": "string", "default": "~/.airtype/models" },
            "model_filename": { "type": "string", "default": "ggml-large-v3-turbo-q5_0.bin" },
            "server_bin": { "type": "string", "default": "/opt/homebrew/bin/whisper-server" },
            "remote_endpoint": { "type": "string", "default": "" },
            "server_args": {
              "type": "string",
              "default": "",
              "description": "Extra arguments passed to local whisper-server."
            },
            "language": { "type": "string", "enum": ["zh-tw", "zh-cn", "en", "ja", "ko"], "default": "zh-tw" },
            "beam": { "type": "integer", "minimum": 1, "maximum": 16, "default": 5 },
            "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0 }
          }
        },
        "yt-dlp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cookies": {
              "type": "string",
              "default": "",
              "description": "Optional cookies.txt path passed to yt-dlp with --cookies."
            },
            "cookies_from_browser": {
              "type": "string",
              "default": "chrome",
              "description": "Optional browser name passed to yt-dlp with --cookies-from-browser, e.g. chrome, safari, firefox, edge."
            }
          }
        },
        "llm-server": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "default": "llama.cpp" },
              "provider": { "type": "string", "default": "openai" },
              "endpoint": { "type": "string", "default": "http://114.34.75.131:8088/" },
              "api_key": {
                "type": "string",
                "default": "",
                "description": "Optional bearer token used when calling this LLM endpoint."
              },
              "models": {
                "type": "array",
                "items": { "type": "string" },
                "default": ["gemma-4-e2b", "qwen3-coder-30b", "qwen3-coder-30b-1m", "qwen3-coder-next", "qwen3-vl-30b-a3b-thinking", "qwen3.6-27b", "qwen3.6-35b-a3b", "unsloth/Qwen3-VL-30B-A3B-Thinking-GGUF:Q4_K_XL", "unsloth/Qwen3.6-27B-MTP-GGUF:Q4_K_XL", "unsloth/Qwen3.6-35B-A3B-MTP-GGUF:Q4_K_XL", "unsloth/gemma-4-E2B-it-GGUF:Q4_K_XL"]
              },
              "selected-model": { "type": "string", "default": "gemma-4-e2b" },
              "contextLength": { "type": "integer", "minimum": 1, "default": 8192 },
              "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.4 },
              "system": {
                "type": "string",
                "default": "No explanations or detailed listings are needed; simply organize the verbatim transcript, including correcting typos, polishing sentences, and stringing the transcript together into an article."
              }
            }
          }
        },
        "default-llm-server-name": {
          "type": "string",
          "default": "llama.cpp",
          "description": "Name of the default LLM server (matches the `name` field in [[webui.llm-server]]."
        }
      }
    }
  }
}
